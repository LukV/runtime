# Copy to .env (gitignored) and adjust. Never commit real secrets.

ENVIRONMENT=development

# Local Supabase stack (`supabase start`): DB on port 54322, password "postgres".
# Production (Railway) uses the Supabase **Session pooler** connection string
# (IPv4-compatible) — NOT the direct db.<ref>.supabase.co:5432 host, which is
# IPv6-only. The pooler string is set as a Railway env var, never in the repo.
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Comma-separated browser origins allowed via CORS (the Next.js app).
CORS_ORIGINS=http://localhost:3000
